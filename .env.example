# ---- Domain ----
# Every host + URL derives from this. hub.<BASE_DOMAIN>, <app>.<BASE_DOMAIN>.
BASE_DOMAIN=grmc.app

# ---- Hub session ----
# Use a long random string (>=32 chars), e.g. `openssl rand -hex 32`
SESSION_SECRET=replace-with-32+char-random-string

# ---- Google OIDC ----
# Create a Web Application OAuth client in Google Cloud Console.
# Authorized redirect URI MUST be: https://hub.grmc.app/auth/callback
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me

# ---- Postgres superuser (container bootstrap) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=postgres

# ---- Per-app databases (created by db/init/01-databases.sh) ----
HUB_DB_NAME=hub
HUB_DB_USER=hub_user
HUB_DB_PASSWORD=replace-hub-db-password

WHOAMI_DB_NAME=whoami
WHOAMI_DB_USER=whoami_user
WHOAMI_DB_PASSWORD=replace-whoami-db-password

SOCIALPOSTS_DB_NAME=socialposts
SOCIALPOSTS_DB_USER=socialposts_user
SOCIALPOSTS_DB_PASSWORD=replace-socialposts-db-password

APPROVALS_DB_NAME=approvals
APPROVALS_DB_USER=approvals_user
APPROVALS_DB_PASSWORD=replace-approvals-db-password

# ---- TLS (Let's Encrypt via Cloudflare DNS-01) ----
# Email for Let's Encrypt registration/expiry notices.
ACME_EMAIL=you@example.com
# Cloudflare API token scoped to Zone:DNS:Edit for the BASE_DOMAIN zone.
CF_DNS_API_TOKEN=replace-with-cloudflare-dns-edit-token
